@using KPIDash.UI.Models
@inject HttpClient Http

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0">Equipment Status Timeline</h4>
    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-outline-secondary" @onclick="PrevShift">← Shift</button>
        <span class="text-muted small px-2">
            @displayedShift.Name · @displayedShift.Start.ToString("MMM d, HH:mm") – @displayedShift.End.ToString("HH:mm") UTC
        </span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="NextShift" disabled="@IsCurrentShift">Shift →</button>
        <button class="btn btn-sm btn-secondary" @onclick="JumpToNow" disabled="@IsCurrentShift">Now</button>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-secondary" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
    </div>
}
else
{
    <EquipmentLineTimeline LineName="Line 1"
                           LineEquipment="line1Equipment"
                           StatusData="statusData"
                           WindowStart="displayedShift.Start"
                           WindowEnd="displayedShift.End"
                           DataCutoff="DataCutoff" />

    <EquipmentLineTimeline LineName="Line 2"
                           LineEquipment="line2Equipment"
                           StatusData="statusData"
                           WindowStart="displayedShift.Start"
                           WindowEnd="displayedShift.End"
                           DataCutoff="DataCutoff" />

    <div class="d-flex gap-4 mt-2">
        <span><span style="color: #28a745;">●</span> Running</span>
        <span><span style="color: #ffc107;">●</span> Idle</span>
        <span><span style="color: #dc3545;">●</span> Down</span>
        <span><span style="color: #adb5bd;">●</span> Unknown</span>
    </div>
}

@code {
    private static Shift GetShiftAt(DateTime t)
    {
        var d = t.Date;
        return t.Hour switch
        {
            >= 6 and < 14  => new("Day",       d.AddHours(6),             d.AddHours(14)),
            >= 14 and < 22 => new("Afternoon", d.AddHours(14),            d.AddHours(22)),
            >= 22          => new("Night",     d.AddHours(22),             d.AddDays(1).AddHours(6)),
            _              => new("Night",     d.AddDays(-1).AddHours(22), d.AddHours(6)),
        };
    }

    private static Shift GetCurrentShift() => GetShiftAt(DateTime.UtcNow);

    private Shift displayedShift = GetCurrentShift();
    private bool IsCurrentShift => displayedShift.Start == GetCurrentShift().Start;
    private DateTime DataCutoff => IsCurrentShift ? DateTime.UtcNow : displayedShift.End;

    private List<Equipment> allEquipment = new();
    private List<Equipment> line1Equipment = new();
    private List<Equipment> line2Equipment = new();
    private Dictionary<int, List<EquipmentStatus>> statusData = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        allEquipment = await Http.GetFromJsonAsync<List<Equipment>>("/api/equipment/") ?? new();
        line1Equipment = allEquipment.Where(e => e.Name.StartsWith("Line 1")).OrderBy(e => e.DisplayOrder).ToList();
        line2Equipment = allEquipment.Where(e => e.Name.StartsWith("Line 2")).OrderBy(e => e.DisplayOrder).ToList();
        await LoadStatusData();
    }

    private async Task LoadStatusData()
    {
        isLoading = true;
        StateHasChanged();

        var tasks = allEquipment.Select(async e =>
        {
            var url = $"/api/equipment/{e.EquipmentId}/status/history?from={displayedShift.Start:o}&to={displayedShift.End:o}";
            var records = await Http.GetFromJsonAsync<List<EquipmentStatus>>(url) ?? new();
            return (e.EquipmentId, records);
        });

        var results = await Task.WhenAll(tasks);
        statusData = results.ToDictionary(r => r.EquipmentId, r => r.records);

        isLoading = false;
    }

    private async Task PrevShift()
    {
        displayedShift = GetShiftAt(displayedShift.Start.AddMinutes(-1));
        await LoadStatusData();
    }

    private async Task NextShift()
    {
        if (!IsCurrentShift)
        {
            displayedShift = GetShiftAt(displayedShift.End.AddMinutes(1));
            await LoadStatusData();
        }
    }

    private async Task JumpToNow()
    {
        displayedShift = GetCurrentShift();
        await LoadStatusData();
    }
}
