@using KPIDash.UI.Models
@inject HttpClient Http

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0">Equipment Status</h4>
    <ShiftSelector OnShiftChanged="OnShiftChanged" />
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-secondary" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
    </div>
}
else
{
    @* Line 1 *@
    <h5 class="fw-semibold mb-2 text-secondary text-uppercase">Line 1</h5>
    <KpiSummaryCards Data="line1Kpi" />
    <div class="mt-3 mb-5">
        <EquipmentLineTimeline LineName=""
                               LineEquipment="line1Equipment"
                               StatusData="statusData"
                               WindowStart="displayedShift.Start"
                               WindowEnd="displayedShift.End"
                               DataCutoff="DataCutoff" />
    </div>

    @* Line 2 *@
    <h5 class="fw-semibold mb-2 text-secondary text-uppercase">Line 2</h5>
    <KpiSummaryCards Data="line2Kpi" />
    <div class="mt-3 mb-2">
        <EquipmentLineTimeline LineName=""
                               LineEquipment="line2Equipment"
                               StatusData="statusData"
                               WindowStart="displayedShift.Start"
                               WindowEnd="displayedShift.End"
                               DataCutoff="DataCutoff" />
    </div>

    <div class="d-flex gap-4 mt-3">
        <span><span style="color: #28a745;">●</span> Running</span>
        <span><span style="color: #ffc107;">●</span> Idle</span>
        <span><span style="color: #dc3545;">●</span> Down</span>
        <span><span style="color: #adb5bd;">●</span> Unknown</span>
    </div>
}

@code {
    private Shift displayedShift = ShiftSelector.GetCurrentShift();
    private bool IsCurrentShift => displayedShift.Start == ShiftSelector.GetCurrentShift().Start;
    private DateTime DataCutoff => IsCurrentShift ? DateTime.UtcNow : displayedShift.End;

    private List<Equipment> allEquipment = new();
    private List<Equipment> line1Equipment = new();
    private List<Equipment> line2Equipment = new();
    private Dictionary<int, List<EquipmentStatus>> statusData = new();
    private KpiSummary? line1Kpi;
    private KpiSummary? line2Kpi;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        allEquipment = await Http.GetFromJsonAsync<List<Equipment>>("/api/equipment/") ?? new();
        line1Equipment = allEquipment.Where(e => e.Name.StartsWith("Line 1")).OrderBy(e => e.DisplayOrder).ToList();
        line2Equipment = allEquipment.Where(e => e.Name.StartsWith("Line 2")).OrderBy(e => e.DisplayOrder).ToList();
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        await Task.WhenAll(LoadStatusData(), LoadKpiData());

        isLoading = false;
    }

    private async Task LoadStatusData()
    {
        var tasks = allEquipment.Select(async e =>
        {
            var url = $"/api/equipment/{e.EquipmentId}/status/history?from={displayedShift.Start:o}&to={displayedShift.End:o}";
            var records = await Http.GetFromJsonAsync<List<EquipmentStatus>>(url) ?? new();
            return (e.EquipmentId, records);
        });

        var results = await Task.WhenAll(tasks);
        statusData = results.ToDictionary(r => r.EquipmentId, r => r.records);
    }

    private async Task LoadKpiData()
    {
        var shiftDate = displayedShift.Start.ToString("yyyy-MM-dd");
        var shift     = displayedShift.Name;

        var kpiTasks = new[]
        {
            Http.GetFromJsonAsync<KpiSummary>(
                $"/api/kpi/{shiftDate}/{shift}/{Uri.EscapeDataString("Line 1")}"),
            Http.GetFromJsonAsync<KpiSummary>(
                $"/api/kpi/{shiftDate}/{shift}/{Uri.EscapeDataString("Line 2")}"),
        };

        var results = await Task.WhenAll(kpiTasks);
        line1Kpi = results[0];
        line2Kpi = results[1];
    }

    private async Task OnShiftChanged(Shift shift)
    {
        displayedShift = shift;
        await LoadData();
    }
}
