@using KPIDash.UI.Models

<div class="mb-5">
    <h5 class="fw-semibold mb-2 text-secondary text-uppercase timeline-line-label">@LineName</h5>

    <div class="timeline-time-axis mb-1">
        @{
            var totalHours = (int)Math.Round((WindowEnd - WindowStart).TotalHours);
            var step = totalHours <= 4 ? 1 : 2;
        }
        @for (int i = 0; i <= totalHours; i += step)
        {
            <span>@WindowStart.AddHours(i).ToString("HH:mm")</span>
        }
    </div>

    @foreach (var equipment in LineEquipment.OrderBy(e => e.DisplayOrder))
    {
        var segments = BuildSegments(
            StatusData.TryGetValue(equipment.EquipmentId, out var records) ? records : new(),
            WindowStart, WindowEnd, DataCutoff);
        var currentStatus = segments.Count > 0 ? segments[^1].Status : "Unknown";
        var shortName = equipment.Name.Replace("Line 1 ", "").Replace("Line 2 ", "");

        <div class="d-flex align-items-center mb-2">
            <span class="timeline-equipment-name text-truncate" title="@equipment.Name">@shortName</span>
            <div class="timeline-bar flex-grow-1">
                @foreach (var seg in segments)
                {
                    var widthPct = WidthPct(seg.Start, seg.End)
                        .ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                    <div class="timeline-segment"
                         style="width: @widthPct%; background-color: @StatusColor(seg.Status);"
                         title="@seg.Status — @seg.Start.ToString("HH:mm") to @seg.End.ToString("HH:mm")">
                    </div>
                }
            </div>
            <span class="timeline-status-badge ms-2" style="color: @StatusColor(currentStatus);">
                ● @currentStatus
            </span>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string LineName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public List<Equipment> LineEquipment { get; set; } = new();
    [Parameter, EditorRequired] public Dictionary<int, List<EquipmentStatus>> StatusData { get; set; } = new();
    [Parameter, EditorRequired] public DateTime WindowStart { get; set; }
    [Parameter, EditorRequired] public DateTime WindowEnd { get; set; }
    [Parameter, EditorRequired] public DateTime DataCutoff { get; set; }

    private static string StatusColor(string status) => status switch
    {
        "Running" => "#28a745",
        "Idle"    => "#ffc107",
        "Down"    => "#dc3545",
        _         => "#adb5bd"
    };

    private double WidthPct(DateTime start, DateTime end) =>
        (end - start).TotalSeconds / (WindowEnd - WindowStart).TotalSeconds * 100.0;

    private List<(DateTime Start, DateTime End, string Status)> BuildSegments(
        List<EquipmentStatus> records, DateTime windowStart, DateTime windowEnd, DateTime dataCutoff)
    {
        var segments = new List<(DateTime Start, DateTime End, string Status)>();

        if (records.Count == 0)
        {
            segments.Add((windowStart, windowEnd, "Unknown"));
            return segments;
        }

        var sorted = records.OrderBy(r => r.RecordedAt.ToUniversalTime()).ToList();

        var baseline = sorted.LastOrDefault(r => r.RecordedAt.ToUniversalTime() <= windowStart);
        var inWindow = sorted.Where(r => r.RecordedAt.ToUniversalTime() > windowStart).ToList();

        var cursor = windowStart;
        var currentStatus = baseline?.Status ?? "Unknown";

        foreach (var record in inWindow)
        {
            var recordedAt = record.RecordedAt.ToUniversalTime();
            var segEnd = recordedAt < dataCutoff ? recordedAt : dataCutoff;
            if (segEnd > cursor)
                segments.Add((cursor, segEnd, currentStatus));
            cursor = segEnd;
            currentStatus = record.Status;
            if (cursor >= dataCutoff) break;
        }

        if (cursor < dataCutoff)
            segments.Add((cursor, dataCutoff, currentStatus));

        if (dataCutoff < windowEnd)
            segments.Add((dataCutoff, windowEnd, "Unknown"));

        return segments;
    }
}
